{
  "grammars": [
    {
      "name": "@cmotion/cmotion",
      "camelcase": "CmotionCmotion",
      "scope": "source.cmotion",
      "path": ".",
      "file-types": [
        "cm"
      ]
    }
  ],
  "metadata": {
    "version": "0.0.1",
    "license": "MIT",
    "description": "Tree-sitter grammar for the cmotion DSL",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-@cmotion/cmotion"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
