---
// /playground — interactive page that drives the live render API.
//
// Paste a `.cm` source, pick frame or video, hit render. The page
// POSTs to https://api.cmotion.org/v1/{frame|render}, polls
// /v1/jobs/<id> until done, then shows the result inline.
//
// Asset upload is in the UI but not yet wired through — the
// `POST /v1/assets` endpoint isn't built. See the note next to
// the file picker.
//
// Unlike `/editor`, the render happens *server-side* (Cloudflare
// Container + Chromium + ffmpeg). Same output bytes the editor
// would have produced, but doesn't tax the user's browser.

const defaultSource = `runner "0.0.1";

use std.shapes.*;
use std.anim.*;

scene quick(duration: Duration = 3s) -> Frame {
  let bg = rect(width: 1920px, height: 1080px, fill: oklch(0.10, 0.04, 280));
  let hue = animate { 0s => 0deg, 3s => 360deg } with { repeat: forever };
  let fg = rect(width: 300px, height: 300px, fill: oklch(0.65, 0.20, hue));
  compose [bg, fg]
}
`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>cmotion · API playground</title>
    <link rel="icon" href="/favicon.svg" />
    <style>
      :root {
        color-scheme: light;
        --bg: #fff;
        --fg: #000;
        --muted: #777;
        --hair: #d8d8d8;
        --accent: #000;
        --accent-fg: #fff;
        --panel: #fafafa;
        --warn: #b00020;
        --ok: #0a7a3a;
        --soft: rgba(0,0,0,0.025);
      }
      html, body { margin: 0; height: 100%; background: var(--bg); color: var(--fg);
        font: 13px/1.45 ui-sans-serif, system-ui, sans-serif; }
      body { display: grid; grid-template-rows: 44px 1fr; }
      header { display: flex; align-items: center; gap: 10px; padding: 0 14px;
        border-bottom: 1px solid var(--hair); background: var(--bg); }
      header h1 { font-size: 13px; font-weight: 600; margin: 0; }
      header h1 a { color: var(--fg); text-decoration: none; }
      header h1 .sep { color: var(--muted); padding: 0 6px; font-weight: 400; }
      header .spacer { flex: 1; }
      header a.docs { color: var(--muted); font-size: 12px; text-decoration: none; }
      header a.docs:hover { color: var(--fg); }
      main { display: grid; grid-template-columns: 1fr 1fr; min-height: 0; }
      .pane { display: flex; flex-direction: column; min-height: 0; min-width: 0;
        overflow: auto; }
      .pane + .pane { border-left: 1px solid var(--hair); }
      .controls { display: flex; flex-direction: column; gap: 14px;
        padding: 16px; }
      .controls section { display: flex; flex-direction: column; gap: 6px; }
      .controls h2 { font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em;
        color: var(--muted); margin: 0; font-weight: 600; }
      textarea#src {
        width: 100%; box-sizing: border-box; padding: 10px;
        background: var(--panel); border: 1px solid var(--hair); border-radius: 4px;
        outline: 0; resize: vertical; min-height: 260px;
        font: 12px/1.5 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        color: var(--fg); tab-size: 2;
      }
      .params { display: grid; grid-template-columns: auto auto auto auto;
        gap: 8px 12px; align-items: center; }
      .params label { font-size: 12px; color: var(--muted); }
      .params input[type=number] {
        width: 80px; padding: 4px 6px;
        border: 1px solid var(--hair); border-radius: 4px; font: inherit;
        background: var(--bg); color: var(--fg);
      }
      .assets { padding: 10px; border: 1px dashed var(--hair); border-radius: 4px;
        background: var(--soft); color: var(--muted); font-size: 12px; }
      .assets input[type=file] { display: block; margin-top: 6px; font-size: 12px; }
      .assets .files { margin-top: 6px; }
      .assets .files li { margin: 0; padding: 2px 0; font-family: ui-monospace, monospace;
        font-size: 11px; color: var(--fg); }
      .assets .note { font-style: italic; }
      .buttons { display: flex; gap: 8px; align-items: center; }
      button { background: var(--accent); color: var(--accent-fg); border: 0;
        padding: 8px 14px; border-radius: 4px; cursor: pointer; font: inherit;
        font-weight: 600; }
      button.secondary { background: transparent; color: var(--fg);
        border: 1px solid var(--hair); font-weight: 500; }
      button:disabled { opacity: 0.4; cursor: progress; }
      .status-bar { display: flex; align-items: center; gap: 10px;
        padding: 10px 16px; border-top: 1px solid var(--hair);
        background: var(--panel); }
      .status-bar .status { flex: 1; font-size: 12px; color: var(--muted);
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-variant-numeric: tabular-nums;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .status-bar button.dl {
        background: var(--accent); color: var(--accent-fg);
        padding: 4px 10px; border-radius: 4px; border: 0;
        font: 600 12px/1.4 ui-sans-serif, system-ui, sans-serif;
        cursor: pointer;
      }
      .status-bar button.dl[aria-hidden="true"] { display: none; }
      .status-bar button.dl:hover { opacity: 0.85; }
      .status-bar button.dl:disabled { opacity: 0.4; cursor: progress; }
      .status.ok { color: var(--ok); }
      .status.err { color: var(--warn); }
      /* Dark stage — `position: relative` so the media positions
         absolutely against it, sidestepping the flex-sizing quirks
         that were clipping the image's bottom edge. */
      .stage { position: relative; background: #111;
        flex: 1; min-height: 0; min-width: 0;
        overflow: hidden; }
      .stage .placeholder {
        position: absolute; inset: 0;
        display: flex; align-items: center; justify-content: center;
        color: #888; font-size: 13px; text-align: center;
        padding: 20px; box-sizing: border-box; line-height: 1.5;
      }
      /* The reliable "media fits inside a frame" pattern: position
         the element at the stage edges (inset by the padding we
         want) and let object-fit: contain handle the letterboxing.
         Decoupled from flex so max-height: 100% can't get
         miscalculated. */
      .stage img, .stage video {
        position: absolute;
        inset: 20px;
        width: calc(100% - 40px);
        height: calc(100% - 40px);
        object-fit: contain;
        background: #000;
        box-shadow: 0 6px 20px rgba(0,0,0,0.45);
      }
      /* Transport bar: a real row in the column layout, NOT a
         floating overlay. Always visible below the stage when a
         video is loaded. Buttons: ↺ rewind · ▶/⏸ play/pause · ⏭ skip
         · scrub slider · time display. */
      .transport { display: none; align-items: center; gap: 8px;
        padding: 8px 14px; border-top: 1px solid var(--hair);
        background: var(--panel); }
      .transport.visible { display: flex; }
      .transport button.tx {
        background: var(--bg); color: var(--fg);
        border: 1px solid var(--hair); padding: 4px 10px; border-radius: 4px;
        font: 600 13px/1 ui-sans-serif, system-ui, sans-serif;
        cursor: pointer; min-width: 36px;
      }
      .transport button.tx:hover { background: var(--panel); }
      .transport .scrub { flex: 1; }
      .transport .scrub input { width: 100%; }
      .transport .t { font-variant-numeric: tabular-nums;
        color: var(--muted); min-width: 96px; font-size: 12px; text-align: right; }
    </style>
  </head>
  <body>
    <header>
      <h1>
        <a href="/">cmotion</a>
        <span class="sep">·</span>
        API playground
      </h1>
      <span class="spacer"></span>
      <a class="docs" href="/api/">API reference →</a>
    </header>

    <main>
      <section class="pane">
        <div class="controls">
          <section>
            <h2>Source</h2>
            <textarea id="src" spellcheck="false" autocapitalize="off" autocorrect="off">{defaultSource}</textarea>
          </section>

          <section>
            <h2>Params</h2>
            <div class="params">
              <label for="p-width">width</label>
              <input id="p-width" type="number" value="1920" min="16" max="3840" />
              <label for="p-height">height</label>
              <input id="p-height" type="number" value="1080" min="16" max="2160" />
              <label for="p-fps">fps</label>
              <input id="p-fps" type="number" value="30" min="1" max="60" />
              <label for="p-duration">duration (s)</label>
              <input id="p-duration" type="number" value="3" min="0.1" max="60" step="0.1" />
              <label for="p-at">at (s)</label>
              <input id="p-at" type="number" value="0" min="0" max="60" step="0.1" />
            </div>
          </section>

          <section>
            <h2>Assets</h2>
            <div class="assets">
              <span class="note">
                Pick images and they get uploaded to <code>POST /v1/assets</code>
                before the render kicks off. Reference them from the source by
                friendly path — a file named <code>earth.png</code> becomes
                <code>image("/earth.png")</code> in your <code>.cm</code> source.
              </span>
              <input id="assets" type="file" accept="image/*" multiple />
              <ul class="files" id="asset-list"></ul>
            </div>
          </section>

          <section>
            <h2>Render</h2>
            <div class="buttons">
              <button id="btn-frame">Render frame</button>
              <button id="btn-video">Render video</button>
              <button class="secondary" id="btn-reset">Reset source</button>
            </div>
          </section>
        </div>
      </section>

      <section class="pane">
        <div class="stage" id="stage">
          <div class="placeholder">
            Hit <strong>Render frame</strong> or <strong>Render video</strong>
            to send the source to <code>api.cmotion.org</code>. The result
            appears here once the job flips to <code>ready</code>.
          </div>
        </div>
        <div class="transport" id="transport"></div>
        <div class="status-bar">
          <span class="status" id="status">idle</span>
          <button class="dl" id="dl" type="button" aria-hidden="true">↓ Download</button>
        </div>
      </section>
    </main>

    <script>
      const API_BASE = "https://api.cmotion.org";
      // Polling cadence — videos render slow (~3× duration + cold
      // start), so we don't want to hammer /v1/jobs/<id> every 1.5s
      // for a job we know will take 20+ seconds.
      const POLL_MS = { frame: 1500, video: 3000 } as const;

      const $ = (id: string) => document.getElementById(id)!;
      const srcEl = $("src") as HTMLTextAreaElement;
      const initialSrc = srcEl.value;
      const status = $("status");
      const stage = $("stage");
      const transport = $("transport");
      const dl = $("dl") as HTMLButtonElement;
      const assetsInput = $("assets") as HTMLInputElement;
      const assetList = $("asset-list");

      function setStatus(msg: string, kind: "info" | "ok" | "err" = "info") {
        status.className = "status" + (kind === "ok" ? " ok" : kind === "err" ? " err" : "");
        status.textContent = msg;
      }

      // Download via fetch → blob → ephemeral <a download>. Doing it
      // this way works across origins (api.cmotion.org → cmotion.org)
      // — the plain `<a href download>` attribute is ignored by
      // browsers when the URL is cross-origin, which is why the
      // earlier version just opened the video in a new tab.
      let dlUrl: string | null = null;
      let dlName = "";
      dl.addEventListener("click", async () => {
        if (!dlUrl) return;
        dl.disabled = true;
        try {
          const res = await fetch(dlUrl);
          const blob = await res.blob();
          const obj = URL.createObjectURL(blob);
          const a = document.createElement("a");
          a.href = obj;
          a.download = dlName;
          document.body.appendChild(a);
          a.click();
          a.remove();
          // Give the browser a tick to start the download before
          // revoking — otherwise some browsers cancel the save.
          setTimeout(() => URL.revokeObjectURL(obj), 1000);
        } finally {
          dl.disabled = false;
        }
      });
      function setDownload(url: string | null, filename = "") {
        dlUrl = url;
        dlName = filename;
        if (url) dl.removeAttribute("aria-hidden");
        else dl.setAttribute("aria-hidden", "true");
      }

      function clearStage(placeholderHTML?: string) {
        if (placeholderHTML) {
          stage.innerHTML = `<div class="placeholder">${placeholderHTML}</div>`;
        } else {
          stage.innerHTML = "";
        }
        transport.classList.remove("visible");
        transport.innerHTML = "";
      }
      function setBusy(busy: boolean) {
        ($("btn-frame") as HTMLButtonElement).disabled = busy;
        ($("btn-video") as HTMLButtonElement).disabled = busy;
      }

      assetsInput.addEventListener("change", () => {
        assetList.innerHTML = "";
        for (const f of Array.from(assetsInput.files ?? [])) {
          const li = document.createElement("li");
          li.textContent = `${f.name} · ${(f.size / 1024).toFixed(1)} KB`;
          assetList.appendChild(li);
        }
      });

      $("btn-reset").addEventListener("click", () => { srcEl.value = initialSrc; });

      // Upload any selected files to /v1/assets and return the
      // path-in-source → asset-key map ready to thread into the
      // render call. Filename `earth.png` is mapped to source path
      // `/earth.png` so users can write `image("/earth.png")`.
      async function uploadAssets(): Promise<Record<string, string>> {
        const files = Array.from(assetsInput.files ?? []);
        if (files.length === 0) return {};
        const form = new FormData();
        for (const f of files) form.append(f.name, f, f.name);
        const res = await fetch(`${API_BASE}/v1/assets`, { method: "POST", body: form });
        if (!res.ok) {
          const body = await res.text();
          throw new Error(`asset upload failed: HTTP ${res.status} · ${body}`);
        }
        const body = await res.json() as { assets: Record<string, string> };
        // Map filename → asset key into source-path → asset key.
        const out: Record<string, string> = {};
        for (const [filename, key] of Object.entries(body.assets)) {
          out[`/${filename}`] = key;
        }
        return out;
      }

      async function enqueue(kind: "frame" | "video", assets: Record<string, string>): Promise<string> {
        const source = srcEl.value;
        const params: Record<string, number> = {};
        const width = parseInt(($("p-width") as HTMLInputElement).value, 10);
        const height = parseInt(($("p-height") as HTMLInputElement).value, 10);
        if (width)  params.width  = width;
        if (height) params.height = height;
        if (kind === "frame") {
          const at = parseFloat(($("p-at") as HTMLInputElement).value);
          if (!Number.isNaN(at)) params.at = at;
        } else {
          const fps = parseInt(($("p-fps") as HTMLInputElement).value, 10);
          const duration = parseFloat(($("p-duration") as HTMLInputElement).value);
          if (fps) params.fps = fps;
          if (!Number.isNaN(duration)) params.duration = duration;
        }

        // Note the endpoint and the "kind" disagree by design:
        //   POST /v1/frame    → kind=frame
        //   POST /v1/render   → kind=video
        // The API endpoint name follows the verb (render / frame);
        // the kind on the job is what's stored.
        const endpoint = kind === "frame" ? "/v1/frame" : "/v1/render";
        const res = await fetch(`${API_BASE}${endpoint}`, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ source, params, assets }),
        });
        if (!res.ok) {
          const body = await res.text();
          throw new Error(`enqueue failed: HTTP ${res.status} · ${body}`);
        }
        const body = await res.json() as { job_id: string };
        return body.job_id;
      }

      // Format milliseconds as a compact "12.3 s" / "1m04 s"
      // string suited for an in-place updating timer.
      function fmtElapsed(ms: number): string {
        if (ms < 60_000) return `${(ms / 1000).toFixed(1)} s`;
        const m = Math.floor(ms / 60_000);
        const s = Math.floor((ms % 60_000) / 1000);
        return `${m}m${String(s).padStart(2, "0")} s`;
      }

      async function poll(id: string, kind: "frame" | "video", t0: number): Promise<any> {
        const interval = POLL_MS[kind];
        // Live elapsed-time tick — updates the status line in-place
        // every 100 ms so the user sees a smooth counter, not the
        // discrete poll cadence.
        const tick = setInterval(() => {
          const ms = performance.now() - t0;
          setStatus(`rendering ${kind} · ${fmtElapsed(ms)} …`);
        }, 100);
        try {
          while (true) {
            await new Promise((r) => setTimeout(r, interval));
            const res = await fetch(`${API_BASE}/v1/jobs/${id}`);
            const body = await res.json();
            if (body.status === "ready") return body;
            if (body.status === "error") {
              throw new Error(body.message || "render failed");
            }
          }
        } finally {
          clearInterval(tick);
        }
      }

      // Populate the dedicated #transport row (NOT overlaid on the
       // video). Matches /editor's `.controls` pattern: ↺ rewind ·
       // ▶/⏸ play-pause · ⏭ skip-to-end · scrub slider · time.
      function mountVideoTransport(v: HTMLVideoElement) {
        v.controls = false;
        transport.innerHTML = "";
        transport.classList.add("visible");

        const back = document.createElement("button");
        back.className = "tx"; back.textContent = "↺"; back.title = "Rewind to start";
        back.addEventListener("click", () => { v.currentTime = 0; });

        const play = document.createElement("button");
        play.className = "tx"; play.textContent = "▶"; play.title = "Play";
        play.addEventListener("click", () => { if (v.paused) v.play(); else v.pause(); });
        v.addEventListener("play",  () => { play.textContent = "⏸"; play.title = "Pause"; });
        v.addEventListener("pause", () => { play.textContent = "▶"; play.title = "Play"; });

        const skip = document.createElement("button");
        skip.className = "tx"; skip.textContent = "⏭"; skip.title = "Skip to end";
        skip.addEventListener("click", () => {
          if (Number.isFinite(v.duration)) v.currentTime = v.duration;
        });

        const scrubWrap = document.createElement("div");
        scrubWrap.className = "scrub";
        const scrub = document.createElement("input");
        scrub.type = "range"; scrub.min = "0"; scrub.max = "0"; scrub.step = "0.01"; scrub.value = "0";
        scrubWrap.appendChild(scrub);

        const t = document.createElement("span");
        t.className = "t"; t.textContent = "0.00 / 0.00s";

        function fmtT(s: number) { return s.toFixed(2); }
        function syncFromVideo() {
          if (Number.isFinite(v.duration)) scrub.max = String(v.duration);
          scrub.value = String(v.currentTime || 0);
          t.textContent = `${fmtT(v.currentTime || 0)} / ${fmtT(v.duration || 0)}s`;
        }
        v.addEventListener("loadedmetadata", syncFromVideo);
        v.addEventListener("timeupdate", syncFromVideo);
        scrub.addEventListener("input", () => { v.currentTime = parseFloat(scrub.value); });

        transport.appendChild(back);
        transport.appendChild(play);
        transport.appendChild(skip);
        transport.appendChild(scrubWrap);
        transport.appendChild(t);
      }

      async function render(kind: "frame" | "video") {
        clearStage(`Rendering ${kind}…`);
        setBusy(true);
        setDownload(null);
        const t0 = performance.now();
        try {
          const fileCount = (assetsInput.files?.length ?? 0);
          if (fileCount > 0) {
            setStatus(`uploading ${fileCount} asset${fileCount === 1 ? "" : "s"} …`);
          }
          const assets = await uploadAssets();
          setStatus(`enqueueing ${kind} …`);
          const id = await enqueue(kind, assets);
          const ready = await poll(id, kind, t0);
          const url = `${API_BASE}${ready.url}`;
          const ms = Math.round(performance.now() - t0);
          setStatus(`done · ${kind} · ${fmtElapsed(ms)}`, "ok");

          const filename = ready.url.split("/").pop()
            || `cmotion.${ready.mime === "image/png" ? "png" : "mp4"}`;
          setDownload(url, filename);

          clearStage();
          if (ready.mime === "image/png") {
            const img = document.createElement("img");
            img.src = url;
            img.alt = "rendered frame";
            stage.appendChild(img);
          } else {
            const v = document.createElement("video");
            v.src = url;
            v.loop = true;
            v.playsInline = true;
            v.preload = "metadata";
            stage.appendChild(v);
            mountVideoTransport(v);
          }
        } catch (e: any) {
          setStatus(`error: ${e?.message ?? e}`, "err");
          clearStage(`Failed — see status below.`);
        } finally {
          setBusy(false);
        }
      }

      $("btn-frame").addEventListener("click", () => render("frame"));
      $("btn-video").addEventListener("click", () => render("video"));
    </script>
  </body>
</html>
