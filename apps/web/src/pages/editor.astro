---
// /editor — fresh, unlinked sandbox for the cmotion DSL.
//
// This page intentionally bypasses Starlight's layout: it's a
// full-bleed editor + live preview, not a docs page. It's unlisted
// (no sidebar entry, no nav link) until the editor experience is
// solid enough to feature.
//
// Architecture:
//   - The browser runs the cmotion *interpreter* (cmotion-render.wasm)
//     — parse + lower + eval + sampler — and feeds the resulting JSON
//     value tree to a Three.js renderer (src/scripts/cmotion-viewer.ts).
//   - Hitting "Render" re-parses the source and seeks to t=0.
//   - "Play" runs an rAF loop over the declared duration; "Download
//     WebM" records the same loop via canvas.captureStream.
//
// The video length is read from the source itself
// (`duration: Duration = 6s` style), so the download button records
// exactly what the .cm declares.

const initialSource = `// edit me — render to apply
runner "0.0.1";

use std.shapes.*;
use std.mesh3d.*;
use std.text;
use std.lighting.*;
use std.scene3d.*;
use std.anim.*;

scene title(duration: Duration = 6s) -> Frame {
  let bg = rect(width: 1920px, height: 1080px, fill: oklch(0.10, 0.04, 280));

  let rot   = animate { 0s => 0deg,   6s => 360deg } with { repeat: forever };
  let hue   = animate { 0s => 280deg, 4s => 640deg } with { repeat: forever };
  let pulse = animate {
                0s    => 1.00,
                500ms => 1.06,
                1s    => 1.00,
              } with { easing: easing.out_cubic, repeat: forever };

  let wobble = wave(amplitude: 8.6deg, period: 12s);

  let glyph = extrude(text.glyph("C", font: "Inter Bold"), depth: 16px)
                .material(fill: oklch(0.78, 0.20, hue),
                          metalness: 0.25,
                          roughness: 0.35,
                          emissive: oklch(0.65, 0.18, hue),
                          emissive_intensity: 0.6)
                .rotate(x: wobble, y: rot)
                .scale(pulse);

  let lights = [
    ambient(0.35),
    directional(from: vec3(3, 4, 5),    intensity: 1.6),
    directional(from: vec3(-4, -2, -3), intensity: 0.9),
  ];

  compose [
    bg,
    render3d(glyph, lights: lights),
  ]
}
`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>cmotion · editor</title>
    <link rel="icon" href="/favicon.svg" />
    <style>
      :root {
        color-scheme: light;
        --bg: #fff;
        --fg: #000;
        --muted: #777;
        --hair: #d8d8d8;
        --accent: #000;
        --accent-fg: #fff;
        --panel: #fafafa;
        --warn: #b00020;
      }
      html, body { margin: 0; height: 100%; background: var(--bg); color: var(--fg);
        font: 13px/1.4 ui-sans-serif, system-ui, sans-serif; }
      body { display: grid; grid-template-rows: 44px 1fr; }
      header { display: flex; align-items: center; gap: 10px; padding: 0 14px;
        border-bottom: 1px solid var(--hair); background: var(--bg); }
      header h1 { font-size: 13px; font-weight: 600; margin: 0; }
      header h1 a { color: var(--fg); text-decoration: none; }
      header .status { color: var(--muted); font-size: 12px; flex: 1;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      header .status.err { color: var(--warn); }
      button { background: var(--accent); color: var(--accent-fg); border: 0;
        padding: 6px 12px; border-radius: 4px; cursor: pointer; font: inherit;
        font-weight: 600; }
      button.secondary { background: transparent; color: var(--fg);
        border: 1px solid var(--hair); font-weight: 500; }
      button:disabled { opacity: 0.4; cursor: progress; }
      main { display: grid; grid-template-columns: 1fr 1fr; min-height: 0; }
      main.code-hidden { grid-template-columns: 1fr; }
      main.code-hidden .editor { display: none; }
      .pane { display: flex; flex-direction: column; min-height: 0; min-width: 0; }
      .pane + .pane { border-left: 1px solid var(--hair); }
      .editor { position: relative; }
      .code-toolbar { display: flex; align-items: center; gap: 6px;
        padding: 6px 10px; border-bottom: 1px solid var(--hair); background: var(--bg);
        flex-shrink: 0; }
      .code-toolbar .ic { background: transparent; color: var(--fg);
        border: 1px solid var(--hair); padding: 3px 9px; border-radius: 4px;
        font-size: 12px; font-weight: 500; cursor: pointer; font-family: inherit; }
      .code-toolbar .ic:hover:not(:disabled) { background: var(--panel); }
      .code-toolbar .ic:disabled { opacity: 0.35; cursor: not-allowed; }
      .code-toolbar .sep { width: 1px; height: 16px; background: var(--hair); margin: 0 4px; }
      .code-toolbar .spacer { flex: 1; }
      .editor .cm-host { flex: 1; width: 100%; min-height: 0;
        background: var(--panel); }
      .stage { position: relative; background: #111; display: flex;
        align-items: center; justify-content: center; padding: 20px; box-sizing: border-box;
        overflow: hidden; }
      canvas { display: block; background: #000;
        box-shadow: 0 6px 20px rgba(0,0,0,0.45);
        flex-shrink: 0;
        /* width/height are set in JS to letterbox the scene's aspect ratio. */ }
      .controls { position: absolute; left: 12px; right: 12px; bottom: 12px;
        display: flex; align-items: center; gap: 10px; padding: 8px 10px;
        background: rgba(255,255,255,0.92); border: 1px solid var(--hair);
        border-radius: 6px; backdrop-filter: blur(6px); }
      .controls .scrub { flex: 1; }
      .controls .scrub input { width: 100%; }
      .controls .t { font-variant-numeric: tabular-nums; color: var(--muted);
        min-width: 88px; font-size: 12px; text-align: right; }
    </style>

    <!--
      CodeMirror's DOM (`.cm-editor`, `.cm-content`, …) is created by JS
      after the Astro markup is rendered, so it has no `data-astro-cid`
      scope attribute. The completion popover (`.cm-cmotion-*`) is also
      JS-created. Both have to be styled in a global block — scoped rules
      simply don't match.
    -->
    <style is:global>
      .cm-editor { height: 100%; outline: none; background: var(--panel); }
      .cm-editor.cm-focused { outline: none; }
      .cm-scroller {
        font: 13px/1.55 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        padding: 16px 0;
      }
      .cm-content { caret-color: var(--fg); color: var(--fg); }
      .cm-gutters { background: var(--panel); border-right: 1px solid var(--hair);
        color: var(--muted); }
      .cm-activeLine { background: rgba(0,0,0,0.025); }
      .cm-activeLineGutter { background: rgba(0,0,0,0.04); }
      .cm-selectionBackground { background: rgba(0,0,0,0.12) !important; }
      .cm-cursor { border-left-color: var(--fg); }

      .cm-cmotion-popover {
        position: fixed; z-index: 50;
        background: #fff; border: 1px solid #d8d8d8; border-radius: 6px;
        box-shadow: 0 6px 18px rgba(0,0,0,0.15);
        font: 12px/1.45 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        max-height: 240px; overflow-y: auto;
        min-width: 200px; padding: 4px 0;
        color: #000;
      }
      .cm-cmotion-item { display: flex; gap: 10px; padding: 3px 10px; cursor: pointer;
        white-space: nowrap; align-items: baseline; }
      .cm-cmotion-item.sel { background: #000; color: #fff; }
      .cm-cmotion-item.sel .cm-cmotion-sig { color: rgba(255,255,255,0.65); }
      .cm-cmotion-name { font-weight: 600; }
      .cm-cmotion-sig { color: #777; font-size: 11px; }
      .cm-cmotion-empty { padding: 6px 10px; color: #777; font-style: italic; }
    </style>
  </head>
  <body>
    <header>
      <h1><a href="/">cmotion</a> · editor</h1>
      <span class="status" id="status">booting…</span>
      <button class="secondary" id="btn-code" title="Hide code editor (⌘\\)">Hide code</button>
      <button id="btn-render">Render</button>
      <button class="secondary" id="btn-play">Play</button>
      <button class="secondary" id="btn-png" disabled>Save PNG</button>
      <button class="secondary" id="btn-webm" disabled>Save video</button>
    </header>

    <main id="layout">
      <section class="pane editor">
        <div class="code-toolbar">
          <button class="ic" id="btn-undo" title="Undo (⌘Z)" disabled>↶ Undo</button>
          <button class="ic" id="btn-redo" title="Redo (⌘⇧Z)" disabled>↷ Redo</button>
          <span class="sep"></span>
          <button class="ic" id="btn-copy" title="Copy all to clipboard">Copy</button>
          <button class="ic" id="btn-clear" title="Clear the editor">Clear</button>
        </div>
        <div id="src" class="cm-host" data-initial-source={initialSource}></div>
      </section>

      <section class="pane stage">
        <canvas id="stage"></canvas>
        <div class="controls">
          <button class="secondary" id="btn-back" title="seek to 0">↺</button>
          <div class="scrub">
            <input id="scrub" type="range" min="0" max="6" step="0.01" value="0" />
          </div>
          <span class="t" id="tval">0.00 / 6.00s</span>
        </div>
      </section>
    </main>

    <script>
      import { boot } from "../scripts/cmotion-viewer.ts";
      import { saveOrShare } from "../scripts/save.ts";
      import { EditorView, keymap, lineNumbers, highlightActiveLine,
        highlightActiveLineGutter, drawSelection } from "@codemirror/view";
      import { EditorState } from "@codemirror/state";
      import { history, defaultKeymap, historyKeymap, indentWithTab,
        undo, redo, undoDepth, redoDepth } from "@codemirror/commands";
      import { cmotionCompletion } from "../scripts/cmotion-completion.ts";

      const canvas = document.getElementById("stage") as HTMLCanvasElement;
      const srcHost = document.getElementById("src") as HTMLDivElement;
      // The initial program lives on the host element as a data attribute so
      // we keep one server-rendered source of truth between SSR and the CM
      // initial doc.
      const initialDoc = srcHost.dataset.initialSource ?? "";
      delete srcHost.dataset.initialSource;
      const btnUndo = document.getElementById("btn-undo") as HTMLButtonElement;
      const btnRedo = document.getElementById("btn-redo") as HTMLButtonElement;
      const btnCopy = document.getElementById("btn-copy") as HTMLButtonElement;
      const btnClear = document.getElementById("btn-clear") as HTMLButtonElement;

      function refreshHistoryButtons() {
        btnUndo.disabled = undoDepth(cmView.state) === 0;
        btnRedo.disabled = redoDepth(cmView.state) === 0;
      }
      const cmView = new EditorView({
        parent: srcHost,
        state: EditorState.create({
          doc: initialDoc,
          extensions: [
            lineNumbers(),
            highlightActiveLine(),
            highlightActiveLineGutter(),
            drawSelection(),
            history(),
            EditorState.tabSize.of(2),
            EditorView.lineWrapping,
            cmotionCompletion(),
            keymap.of([indentWithTab, ...historyKeymap, ...defaultKeymap]),
            EditorView.updateListener.of((u) => {
              if (u.docChanged || u.transactions.some((t) => t.isUserEvent("undo") || t.isUserEvent("redo"))) {
                refreshHistoryButtons();
              }
            }),
          ],
        }),
      });
      refreshHistoryButtons();

      btnUndo.addEventListener("click", () => { undo(cmView); cmView.focus(); });
      btnRedo.addEventListener("click", () => { redo(cmView); cmView.focus(); });
      btnCopy.addEventListener("click", async () => {
        const text = cmView.state.doc.toString();
        try {
          await navigator.clipboard.writeText(text);
          setStatus(`copied ${text.length} chars to clipboard`);
        } catch (e: any) {
          setStatus(`copy failed: ${e.message}`, true);
        }
      });
      btnClear.addEventListener("click", () => {
        cmView.dispatch({ changes: { from: 0, to: cmView.state.doc.length, insert: "" } });
        cmView.focus();
      });
      // Adapter so the rest of the file can keep reading/writing `srcEl.value`
      // exactly as it did with the textarea.
      const srcEl = {
        get value() { return cmView.state.doc.toString(); },
        set value(v: string) {
          cmView.dispatch({
            changes: { from: 0, to: cmView.state.doc.length, insert: v },
          });
        },
      };
      const statusEl = document.getElementById("status") as HTMLElement;
      const btnRender = document.getElementById("btn-render") as HTMLButtonElement;
      const btnPlay = document.getElementById("btn-play") as HTMLButtonElement;
      const btnPng = document.getElementById("btn-png") as HTMLButtonElement;
      const btnWebm = document.getElementById("btn-webm") as HTMLButtonElement;
      const btnBack = document.getElementById("btn-back") as HTMLButtonElement;
      const btnCode = document.getElementById("btn-code") as HTMLButtonElement;
      const layout = document.getElementById("layout") as HTMLElement;
      const scrub = document.getElementById("scrub") as HTMLInputElement;
      const tVal = document.getElementById("tval") as HTMLElement;

      // Deep link: /editor/#source=<urlencoded .cm source> preloads the editor
      // with that source. Used by the "Edit it →" link on the homepage.
      function preloadFromHash() {
        const hash = location.hash.startsWith("#") ? location.hash.slice(1) : "";
        if (!hash) return;
        const params = new URLSearchParams(hash);
        const src = params.get("source");
        if (src) srcEl.value = src;
      }
      preloadFromHash();

      function setStatus(msg: string, isErr = false) {
        statusEl.textContent = msg;
        statusEl.classList.toggle("err", isErr);
      }
      function formatTime(t: number, total: number) {
        return `${t.toFixed(2)} / ${total.toFixed(2)}s`;
      }

      let view: Awaited<ReturnType<typeof boot>> | null = null;
      let playing = false;
      let playStart = 0;
      let rafId = 0;

      async function renderSource() {
        if (!view) return;
        // Parse+eval is synchronous; yield to paint the "rendering…" state
        // so the user sees the click registered before we block the thread.
        btnRender.disabled = true;
        const renderLabel = btnRender.textContent;
        btnRender.textContent = "Rendering…";
        setStatus("rendering…");
        await new Promise((r) => requestAnimationFrame(() => r(null)));
        const t0 = performance.now();
        try {
          view.load(srcEl.value);
          const d = view.durationSeconds;
          const ms = (performance.now() - t0).toFixed(0);
          scrub.max = String(d);
          scrub.value = "0";
          tVal.textContent = formatTime(0, d);
          setStatus(`rendered in ${ms}ms · interp v${view.versions.cmotion} · three.js r${view.versions.three} · duration ${d}s`);
          btnPng.disabled = false;
          btnWebm.disabled = false;
        } catch (e: any) {
          setStatus(e.message, true);
          btnPng.disabled = true;
          btnWebm.disabled = true;
        } finally {
          btnRender.disabled = false;
          btnRender.textContent = renderLabel;
        }
      }

      function tick() {
        if (!view || !playing) return;
        const elapsed = (performance.now() - playStart) / 1000;
        const d = view.durationSeconds;
        const t = elapsed % d; // loop
        view.seek(t);
        scrub.value = String(t);
        tVal.textContent = formatTime(t, d);
        rafId = requestAnimationFrame(tick);
      }

      function setPlaying(p: boolean) {
        playing = p;
        btnPlay.textContent = p ? "Pause" : "Play";
        if (p) {
          if (!view) return;
          const startT = parseFloat(scrub.value);
          playStart = performance.now() - startT * 1000;
          rafId = requestAnimationFrame(tick);
        } else {
          cancelAnimationFrame(rafId);
        }
      }

      function setCodeHidden(hidden: boolean) {
        layout.classList.toggle("code-hidden", hidden);
        btnCode.textContent = hidden ? "Show code" : "Hide code";
        try { localStorage.setItem("cmotion-play:code-hidden", hidden ? "1" : "0"); } catch {}
        // Force the viewer to recompute its letterbox once the new grid
        // layout has settled. rAF gives the browser one tick to apply the
        // grid-template-columns change before we read parent.clientWidth.
        if (view) requestAnimationFrame(() => view!.resize());
      }
      btnCode.addEventListener("click", () => {
        setCodeHidden(!layout.classList.contains("code-hidden"));
      });
      // ⌘\ / Ctrl+\ to toggle.
      window.addEventListener("keydown", (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === "\\") {
          e.preventDefault();
          setCodeHidden(!layout.classList.contains("code-hidden"));
        }
      });
      // Always open with the code view shown — examples opened via
      // "Open in /editor" should land on the source, not a bare preview.
      // The ⌘\ toggle still hides it within the session.

      btnRender.addEventListener("click", () => {
        setPlaying(false);
        renderSource();
      });
      btnPlay.addEventListener("click", () => setPlaying(!playing));
      btnBack.addEventListener("click", () => {
        setPlaying(false);
        scrub.value = "0";
        if (view) {
          view.seek(0);
          tVal.textContent = formatTime(0, view.durationSeconds);
        }
      });
      scrub.addEventListener("input", () => {
        if (!view) return;
        setPlaying(false);
        const t = parseFloat(scrub.value);
        view.seek(t);
        tVal.textContent = formatTime(t, view.durationSeconds);
      });
      btnPng.addEventListener("click", async () => {
        if (!view) return;
        try {
          const blob = await view.captureFrame();
          if (!blob) throw new Error("canvas.toBlob returned no data");
          const how = await saveOrShare(blob, `cmotion-${Date.now()}.png`);
          setStatus(`PNG ${how} (${(blob.size / 1024).toFixed(1)} KB)`);
        } catch (e: any) {
          setStatus(`PNG: ${e.message}`, true);
        }
      });
      // Two-click flow for video saves. iOS Safari's share sheet requires
      // a "transient user activation" — a user gesture less than ~5 seconds
      // old. Real-time recording exhausts it, so we split the work: first
      // click records, the *second* click (which carries a fresh gesture)
      // actually triggers the save. Desktop benefits too — showSaveFilePicker
      // has the same activation requirement.
      let pendingClip: { blob: Blob; name: string; durationS: number; sizeKB: number } | null = null;
      const btnWebmLabel = btnWebm.textContent || "Save video";

      async function recordClip() {
        if (!view) return;
        btnWebm.disabled = true;
        btnWebm.textContent = "recording…";
        setStatus(`recording ${view.durationSeconds.toFixed(1)}s clip…`);
        setPlaying(false);
        // Reset the timeline so the recording starts from t=0 and the scrub
        // bar visibly tracks playback as the clip is captured.
        const d = view.durationSeconds;
        view.seek(0);
        scrub.value = "0";
        tVal.textContent = formatTime(0, d);
        try {
          const { blob, ext } = await view.captureClip({
            onProgress: (t) => {
              scrub.value = String(t);
              tVal.textContent = formatTime(t, d);
            },
          });
          if (!blob.size) throw new Error("recording produced 0 bytes");
          pendingClip = {
            blob,
            name: `cmotion-${Date.now()}.${ext}`,
            durationS: view.durationSeconds,
            sizeKB: blob.size / 1024,
          };
          btnWebm.textContent = `Save ${pendingClip.sizeKB.toFixed(0)} KB ${ext}`;
          btnWebm.classList.remove("secondary");
          setStatus(`recording done — click "${btnWebm.textContent}" to save`);
        } catch (e: any) {
          setStatus(`video: ${e.message}`, true);
          btnWebm.textContent = btnWebmLabel;
        } finally {
          btnWebm.disabled = false;
        }
      }

      async function saveClip() {
        if (!pendingClip) return;
        const { blob, name, durationS, sizeKB } = pendingClip;
        const ext = name.slice(name.lastIndexOf(".") + 1);
        btnWebm.disabled = true;
        try {
          const how = await saveOrShare(blob, name);
          setStatus(`video ${how} (${sizeKB.toFixed(0)} KB · ${durationS.toFixed(1)}s · ${ext})`);
        } catch (e: any) {
          setStatus(`video: ${e.message}`, true);
        } finally {
          pendingClip = null;
          btnWebm.textContent = btnWebmLabel;
          btnWebm.classList.add("secondary");
          btnWebm.disabled = false;
        }
      }

      btnWebm.addEventListener("click", () => {
        if (pendingClip) saveClip(); else recordClip();
      });

      try {
        view = await boot(canvas);
        renderSource();
      } catch (e: any) {
        setStatus(e.message, true);
      }
    </script>
  </body>
</html>
