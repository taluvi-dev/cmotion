---
// ScenePreview.astro — live preview of the homepage sample, driven by the
// real cmotion interpreter (cmotion-render.wasm) instead of a hand-rolled
// Three.js reproduction. Same source the docs print above; the WASM emits
// a JSON value tree per frame, the viewer translates it into Three.js
// objects. If this preview drifts from the code block, the renderer is
// what's right.
---

<figure class="scene-preview">
  <div class="frame">
    <canvas data-scene-preview aria-label="Live preview of the sample scene"></canvas>
  </div>
  <figcaption>
    <span>Live preview — rendered by the cmotion interpreter running in your browser. <a href="/play/">Edit it →</a></span>
    <button type="button" data-scene-render>Render</button>
  </figcaption>
</figure>

<style>
  .scene-preview { margin: 1.5rem 0 2rem; }
  .scene-preview .frame {
    aspect-ratio: 16 / 9;
    border-radius: 4px;
    border: 1px solid var(--sl-color-hairline);
    background: #000;
    overflow: hidden;
    position: relative;
  }
  .scene-preview canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
  .scene-preview figcaption {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
    margin-top: 0.5rem;
    font-style: italic;
  }
  .scene-preview figcaption button {
    font: inherit; font-style: normal; font-weight: 600;
    padding: 4px 12px; border-radius: 4px;
    background: var(--sl-color-gray-1, #000);
    color: var(--sl-color-bg, #fff);
    border: 0; cursor: pointer;
  }
  .scene-preview figcaption button:disabled { opacity: 0.4; cursor: progress; }
</style>

<script>
  import { boot } from "../scripts/cmotion-viewer.ts";

  // Source must match the code block above on the page. Keep them in sync.
  const HOMEPAGE_SOURCE = `use std.shapes.*;
use std.mesh3d.*;
use std.text;
use std.lighting.*;
use std.scene3d.*;
use std.anim.*;

scene title(duration: Duration = 6s) -> Frame {
  let bg = rect(width: 1920px, height: 1080px, fill: oklch(0.10, 0.04, 280));

  let rot   = animate { 0s => 0deg,   6s => 360deg } with { repeat: forever };
  let hue   = animate { 0s => 280deg, 4s => 640deg } with { repeat: forever };
  let pulse = animate {
                0s    => 1.00,
                500ms => 1.06,
                1s    => 1.00,
              } with { easing: easing.out_cubic, repeat: forever };

  let wobble = wave(amplitude: 8.6deg, period: 12s);

  let glyph = extrude(text.glyph("C", font: "Inter Bold"), depth: 16px)
                .material(fill: oklch(0.78, 0.20, hue),
                          metalness: 0.25,
                          roughness: 0.35,
                          emissive: oklch(0.65, 0.18, hue),
                          emissive_intensity: 0.6)
                .rotate(x: wobble, y: rot)
                .scale(pulse);

  let lights = [
    ambient(0.35),
    directional(from: vec3(3, 4, 5),    intensity: 1.6),
    directional(from: vec3(-4, -2, -3), intensity: 0.9),
  ];

  compose [
    bg,
    render3d(glyph, lights: lights),
  ]
}
`;

  // Encode source for /play. URL hash so it's not sent server-side and
  // refresh-safe. btoa would mangle non-ASCII; use encodeURIComponent.
  function editLinkFor(source: string): string {
    return `/play/#source=${encodeURIComponent(source)}`;
  }

  // Wire up every "Edit it →" link on the page to carry the homepage source.
  for (const a of document.querySelectorAll<HTMLAnchorElement>('a[href="/play/"]')) {
    a.href = editLinkFor(HOMEPAGE_SOURCE);
  }

  async function mount(canvas: HTMLCanvasElement) {
    const figcaption = canvas.closest("figure")?.querySelector("figcaption") ?? null;
    const btnRender = figcaption?.querySelector<HTMLButtonElement>("button[data-scene-render]") ?? null;

    let view: Awaited<ReturnType<typeof boot>>;
    try {
      view = await boot(canvas);
      view.load(HOMEPAGE_SOURCE);
    } catch (e) {
      console.error("[cmotion homepage preview]", e);
      return;
    }

    // Only render when the canvas is on screen; idle when scrolled away.
    let visible = true;
    const io = new IntersectionObserver(
      (entries) => { for (const e of entries) visible = e.isIntersecting; },
      { threshold: 0 },
    );
    io.observe(canvas);

    let running = true;
    let raf = 0;
    let start = performance.now();
    function frame(now: number) {
      if (!running) return;
      if (visible) {
        const t = ((now - start) / 1000) % view.durationSeconds;
        view.seek(t);
      }
      raf = requestAnimationFrame(frame);
    }
    raf = requestAnimationFrame(frame);

    // Click "Render" → re-parse the source and restart the loop at t=0.
    // Re-parsing exercises the interpreter freshly; useful if the user wants
    // to confirm the preview is genuinely WASM-driven.
    if (btnRender) {
      btnRender.addEventListener("click", () => {
        btnRender.disabled = true;
        try {
          view.load(HOMEPAGE_SOURCE);
          start = performance.now();
        } finally {
          btnRender.disabled = false;
        }
      });
    }

    // Astro view transitions: dispose on navigation to avoid leaking the WASM
    // module + WebGL context.
    document.addEventListener(
      "astro:before-swap",
      () => {
        running = false;
        cancelAnimationFrame(raf);
        io.disconnect();
        view.destroy();
      },
      { once: true },
    );
  }

  for (const c of document.querySelectorAll<HTMLCanvasElement>("canvas[data-scene-preview]")) {
    mount(c);
  }
</script>
