---
// ScenePreview.astro — inline cmotion playground on the homepage.
// Renders an editable source textarea + a live preview, both driven by
// cmotion-render.wasm. Same renderer /editor uses; this is just the
// minimal control surface (no PNG/video save — those are /editor's job).
---

<figure class="scene-preview">
  <textarea class="source" data-scene-source spellcheck="false" autocapitalize="off" autocorrect="off"></textarea>
  <div class="frame">
    <canvas data-scene-preview aria-label="Live preview of the sample scene"></canvas>
  </div>
  <figcaption>
    <span>Edit above, click <strong>Render</strong> to apply. <a href="/editor/">Open in /editor →</a></span>
    <button type="button" data-scene-render>Render</button>
  </figcaption>
</figure>

<style>
  .scene-preview { margin: 1.5rem 0 2rem; }

  .scene-preview .source {
    display: block;
    width: 100%;
    box-sizing: border-box;
    height: 22em;
    margin: 0 0 0.75rem;
    padding: 12px 14px;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 4px;
    background: var(--sl-color-bg-inline-code, #f6f6f6);
    color: var(--sl-color-text, #111);
    font: 0.85rem/1.55 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    tab-size: 2;
    resize: vertical;
    outline: none;
  }
  .scene-preview .source:focus { border-color: var(--sl-color-accent, #555); }

  .scene-preview .frame {
    aspect-ratio: 16 / 9;
    border-radius: 4px;
    border: 1px solid var(--sl-color-hairline);
    background: #000;
    overflow: hidden;
    position: relative;
  }
  .scene-preview canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  .scene-preview figcaption {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
    margin-top: 0.5rem;
    font-style: italic;
  }
  .scene-preview figcaption button {
    font: inherit; font-style: normal; font-weight: 600;
    padding: 4px 12px; border-radius: 4px;
    background: var(--sl-color-gray-1, #000);
    color: var(--sl-color-bg, #fff);
    border: 0; cursor: pointer;
  }
  .scene-preview figcaption button:disabled { opacity: 0.4; cursor: progress; }
  .scene-preview figcaption .err { color: var(--sl-color-red, #b00020); font-style: normal; }
</style>

<script>
  import { boot } from "../scripts/cmotion-viewer.ts";
  import { HOMEPAGE_SOURCE } from "../examples/sources.ts";

  // Update every "Open in /editor →" link with the current homepage source so a
  // visitor lands on /editor with whatever they were just editing.
  function updatePlayLinks(source: string) {
    for (const a of document.querySelectorAll<HTMLAnchorElement>('a[href^="/editor/"]')) {
      a.href = `/editor/#source=${encodeURIComponent(source)}`;
    }
  }

  async function mount(figure: HTMLElement) {
    const canvas = figure.querySelector<HTMLCanvasElement>("canvas[data-scene-preview]");
    const sourceEl = figure.querySelector<HTMLTextAreaElement>("textarea[data-scene-source]");
    const btnRender = figure.querySelector<HTMLButtonElement>("button[data-scene-render]");
    const captionText = figure.querySelector<HTMLElement>("figcaption span");
    if (!canvas || !sourceEl || !btnRender || !captionText) return;
    const captionDefault = captionText.innerHTML;

    sourceEl.value = HOMEPAGE_SOURCE;
    updatePlayLinks(HOMEPAGE_SOURCE);

    let view: Awaited<ReturnType<typeof boot>>;
    try {
      view = await boot(canvas);
      view.load(HOMEPAGE_SOURCE);
    } catch (e) {
      console.error("[cmotion homepage preview]", e);
      return;
    }

    // Only render when the canvas is on screen; idle when scrolled away.
    let visible = true;
    const io = new IntersectionObserver(
      (entries) => { for (const e of entries) visible = e.isIntersecting; },
      { threshold: 0 },
    );
    io.observe(canvas);

    let running = true;
    let raf = 0;
    let start = performance.now();
    function frame(now: number) {
      if (!running) return;
      if (visible) {
        const t = ((now - start) / 1000) % view.durationSeconds;
        try { view.seek(t); } catch { /* skip frame on transient sampler error */ }
      }
      raf = requestAnimationFrame(frame);
    }
    raf = requestAnimationFrame(frame);

    btnRender.addEventListener("click", () => {
      btnRender.disabled = true;
      captionText.classList.remove("err");
      captionText.innerHTML = captionDefault;
      const src = sourceEl.value;
      try {
        view.load(src);
        start = performance.now();
        updatePlayLinks(src);
      } catch (e: any) {
        captionText.textContent = String(e?.message ?? e);
        captionText.classList.add("err");
      } finally {
        btnRender.disabled = false;
      }
    });

    // ⌘/Ctrl+Enter inside the editor renders, like a notebook cell.
    sourceEl.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "Enter") {
        e.preventDefault();
        btnRender.click();
      }
    });

    // Astro view transitions: dispose on navigation to avoid leaking the WASM
    // module + WebGL context.
    document.addEventListener(
      "astro:before-swap",
      () => {
        running = false;
        cancelAnimationFrame(raf);
        io.disconnect();
        view.destroy();
      },
      { once: true },
    );
  }

  for (const f of document.querySelectorAll<HTMLElement>("figure.scene-preview")) {
    mount(f);
  }
</script>
