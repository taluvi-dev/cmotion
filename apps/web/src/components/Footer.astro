---
// Overrides Starlight's footer: render the built-in footer, then append
// a sponsor thank-you. Registered via `components.Footer` in astro.config.
import Default from '@astrojs/starlight/components/Footer.astro';
---

<Default {...Astro.props} />

<footer class="sponsor">
  <p>
    With thanks to our sponsor
    <a href="https://taluvi.com" target="_blank" rel="noopener noreferrer">taluvi.com</a>
    — <span class="tagline">Tools for Digital Nomads</span>.
  </p>
</footer>

<style>
  .sponsor {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--sl-color-hairline, var(--sl-color-gray-5));
    text-align: center;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
  }
  .sponsor a {
    color: var(--sl-color-text-accent);
    font-weight: 600;
    text-decoration: none;
  }
  .sponsor a:hover { text-decoration: underline; }
  .sponsor .tagline { font-style: italic; }
</style>
